[Unit]
Description=Namma Dashcam verifier service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/namma-dashcam/linux
EnvironmentFile=-/etc/namma-dashcam.env
ExecStart=/usr/bin/env uv run python -m namma_dashcam.main
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
